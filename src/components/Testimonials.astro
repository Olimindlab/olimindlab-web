---
const testimonials = [
  {
    quote: "Olimindlab no solo diseñó nuestra identidad visual, la construyó desde cero entendiendo quiénes somos. El resultado habla por sí solo: más reconocimiento, más coherencia, más negocio.",
    author: "María González",
    role: "CEO, Estudio Bloom",
  },
  {
    quote: "El proceso fue completamente diferente. Antes de proponer nada, escuchó, preguntó y entendió. El sitio web que lanzamos convierte el doble que el anterior.",
    author: "Carlos Ramos",
    role: "Fundador, TechForward",
  },
  {
    quote: "En seis meses pasamos de 200 a más de 8.000 seguidores cualificados. Pero lo más valioso fue construir una comunidad que compra, no solo que sigue.",
    author: "Laura Martínez",
    role: "Directora, Casa Miel",
  },
  {
    quote: "Redujimos el coste por adquisición en un 40% en el primer trimestre. Estrategia clara, ejecución impecable y comunicación constante.",
    author: "Andrés Vila",
    role: "CMO, Nexus Platform",
  },
];
---

<section class="testimonials" id="testimonios">
  <div class="container">

    <div class="testimonials__header">
      <p class="testimonials__label">CLIENTES</p>
      <h2 class="testimonials__title">Lo que dicen<br />quienes trabajan con nosotros.</h2>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((t) => (
        <blockquote class="testimonial">
          <p class="testimonial__quote">"{t.quote}"</p>
          <footer class="testimonial__footer">
            <p class="testimonial__author">{t.author}</p>
            <p class="testimonial__role">{t.role}</p>
          </footer>
        </blockquote>
      ))}
    </div>

  </div>
</section>

<style>
  .testimonials {
    padding: 10rem 0;
    background-color: #ffffff;
    color: #0a0a0a;
  }

  .testimonials__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
    margin-bottom: 5rem;
  }

  .testimonials__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--muted);
    align-self: start;
    padding-top: 0.5rem;
  }

  .testimonials__title {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .testimonial {
    background: var(--white);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .testimonial__quote {
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--black);
  }

  .testimonial__footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .testimonial__author {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--black);
    letter-spacing: -0.01em;
    margin-bottom: 0.125rem;
  }

  .testimonial__role {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .testimonials__header {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .testimonial {
      padding: 2rem;
    }
  }
</style>
