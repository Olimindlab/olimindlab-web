---
const testimonials = [
  {
    quote: "Olimindlab transformó nuestra marca por completo. No solo diseñaron un logo: nos dieron una identidad coherente que ahora reconocen en todos nuestros canales. El ROI fue inmediato.",
    author: "María González",
    role: "CEO, Estudio Bloom",
    initials: "MG",
  },
  {
    quote: "El proceso fue muy diferente a lo que esperaba. Antes de proponer nada, escuchó y preguntó. El resultado es un sitio web que de verdad representa quiénes somos y convierte mucho mejor.",
    author: "Carlos Ramos",
    role: "Fundador, TechForward",
    initials: "CR",
  },
  {
    quote: "Llevábamos años con la misma presencia digital y sin saber cómo mejorarla. En tres meses de trabajo con Olimindlab pasamos de 200 a más de 4.000 seguidores cualificados en Instagram.",
    author: "Laura Martínez",
    role: "Directora creativa, Casa Miel",
    initials: "LM",
  },
  {
    quote: "Claridad, profesionalidad y resultados. La estrategia de marketing digital que desarrollamos juntos redujo nuestro coste por adquisición en un 40% en el primer trimestre.",
    author: "Andrés Vila",
    role: "CMO, Plataforma Nexus",
    initials: "AV",
  },
];
---

<section class="testimonials" id="testimonios">
  <div class="container">
    <div class="testimonials__header">
      <div class="testimonials__label">
        <span class="testimonials__label-line"></span>
        <span>Testimonios</span>
      </div>
      <h2 class="testimonials__title">
        Lo que dicen<br />
        <em>mis clientes</em>
      </h2>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((t, i) => (
        <blockquote class={`testimonial ${i === 0 ? "testimonial--large" : ""}`}>
          <div class="testimonial__quote-mark">"</div>
          <p class="testimonial__text">{t.quote}</p>
          <footer class="testimonial__footer">
            <div class="testimonial__avatar">{t.initials}</div>
            <div class="testimonial__meta">
              <cite class="testimonial__author">{t.author}</cite>
              <span class="testimonial__role">{t.role}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

    <div class="testimonials__cta-row">
      <div class="testimonials__rating">
        <div class="testimonials__stars">
          {"★★★★★".split("").map((s) => <span>{s}</span>)}
        </div>
        <span class="testimonials__rating-text">Valoración media de clientes</span>
      </div>
      <a href="#contacto" class="testimonials__cta">
        Únete a ellos
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M3.5 9h11M10 5.5l3.5 3.5L10 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 8rem 0;
    background: var(--bg-2);
    position: relative;
  }

  .testimonials::before,
  .testimonials::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .testimonials::before { top: 0; }
  .testimonials::after { bottom: 0; }

  .testimonials__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 4rem;
    gap: 2rem;
  }

  .testimonials__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }

  .testimonials__label-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--accent);
  }

  .testimonials__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.95;
    text-align: right;
  }

  .testimonials__title em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .testimonial {
    background: var(--bg);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    transition: background 0.3s ease;
  }

  .testimonial:hover {
    background: var(--bg-3);
  }

  .testimonial--large {
    grid-column: 1 / -1;
    background: var(--bg-3);
  }

  .testimonial--large .testimonial__text {
    font-size: 1.25rem;
  }

  .testimonial--large .testimonial__quote-mark {
    font-size: 8rem;
  }

  .testimonial__quote-mark {
    font-family: var(--font-serif);
    font-size: 5rem;
    line-height: 0.5;
    color: var(--accent);
    opacity: 0.4;
    font-weight: 700;
    height: 2rem;
  }

  .testimonial__text {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text);
    font-weight: 300;
    flex: 1;
    font-style: italic;
    font-family: var(--font-serif);
  }

  .testimonial__footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .testimonial__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 500;
    flex-shrink: 0;
  }

  .testimonial__meta {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonial__author {
    font-style: normal;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .testimonial__role {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .testimonials__cta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .testimonials__rating {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .testimonials__stars {
    display: flex;
    gap: 0.2rem;
    color: var(--accent);
    font-size: 1.25rem;
  }

  .testimonials__rating-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .testimonials__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    padding: 1rem 2rem;
    background: var(--accent);
    transition: background 0.2s, gap 0.2s;
  }

  .testimonials__cta:hover {
    background: var(--accent-2);
    gap: 1.25rem;
  }

  @media (max-width: 768px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonial--large {
      grid-column: 1;
    }

    .testimonials__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .testimonials__title {
      text-align: left;
    }

    .testimonials__cta-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 600px) {
    .testimonial {
      padding: 1.75rem;
    }
  }
</style>
