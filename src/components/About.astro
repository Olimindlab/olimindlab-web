---
const skills = [
  "Dirección de arte", "Brand strategy", "Diseño editorial",
  "Tipografía", "Motion design", "UX Research",
  "Google Ads", "Meta Ads", "Copywriting",
];
---

<section class="about" id="sobre-mi">
  <div class="container about__inner">
    <div class="about__image-col">
      <div class="about__image-frame">
        <div class="about__image-placeholder">
          <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="240" fill="#1a1a1a"/>
            <circle cx="100" cy="90" r="40" fill="#222"/>
            <ellipse cx="100" cy="200" rx="70" ry="50" fill="#222"/>
            <text x="100" y="95" text-anchor="middle" fill="#444" font-size="14" font-family="sans-serif">Tu foto aquí</text>
          </svg>
        </div>
        <div class="about__image-badge">
          <span class="about__image-badge-num">7+</span>
          <span class="about__image-badge-text">años creando</span>
        </div>
      </div>

      <div class="about__skills">
        {skills.map((skill) => (
          <span class="about__skill">{skill}</span>
        ))}
      </div>
    </div>

    <div class="about__content">
      <div class="about__label">
        <span class="about__label-line"></span>
        <span>Sobre mí</span>
      </div>

      <h2 class="about__title">
        Diseño con<br />
        <em>estrategia</em>,<br />
        no solo estética
      </h2>

      <div class="about__bio">
        <p>
          Soy consultora de diseño y marketing digital con más de 7 años ayudando a
          marcas a encontrar su voz, construir su identidad y crecer de forma sostenible.
        </p>
        <p>
          Mi enfoque es diferente: antes de abrir Illustrator o escribir un anuncio,
          entiendo el negocio. Porque el mejor diseño es el que resuelve problemas reales.
        </p>
        <p>
          He trabajado con startups, pymes y marcas consolidadas en sectores tan diversos
          como moda, tecnología, gastronomía y servicios profesionales.
        </p>
      </div>

      <div class="about__values">
        <div class="about__value">
          <span class="about__value-icon">→</span>
          <div>
            <h4 class="about__value-title">Claridad sobre ruido</h4>
            <p class="about__value-desc">Comunicación directa, propuestas sin florituras innecesarias.</p>
          </div>
        </div>
        <div class="about__value">
          <span class="about__value-icon">→</span>
          <div>
            <h4 class="about__value-title">Resultados medibles</h4>
            <p class="about__value-desc">Cada decisión de diseño tiene una razón estratégica detrás.</p>
          </div>
        </div>
        <div class="about__value">
          <span class="about__value-icon">→</span>
          <div>
            <h4 class="about__value-title">Colaboración real</h4>
            <p class="about__value-desc">Trabajamos juntos, no como cliente-proveedor, sino como socios.</p>
          </div>
        </div>
      </div>

      <a href="#contacto" class="about__cta">
        Contáctame
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 8rem 0;
  }

  .about__inner {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 6rem;
    align-items: start;
  }

  /* Image column */
  .about__image-frame {
    position: relative;
    margin-bottom: 2rem;
  }

  .about__image-placeholder {
    width: 100%;
    aspect-ratio: 5/6;
    background: var(--bg-2);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .about__image-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .about__image-badge {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    background: var(--accent);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .about__image-badge-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text);
  }

  .about__image-badge-text {
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    white-space: nowrap;
  }

  .about__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
  }

  .about__skill {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-2);
    transition: border-color 0.2s, color 0.2s;
  }

  .about__skill:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  /* Content */
  .about__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .about__label-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--accent);
  }

  .about__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.95;
    margin-bottom: 2.5rem;
  }

  .about__title em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .about__bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .about__bio p {
    color: var(--text-muted);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .about__values {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding: 2rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
  }

  .about__value {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .about__value-icon {
    color: var(--accent);
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
    font-weight: 300;
  }

  .about__value-title {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .about__value-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .about__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    padding: 1rem 2rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    transition: background 0.2s, border-color 0.2s, gap 0.2s;
  }

  .about__cta:hover {
    background: var(--accent);
    border-color: var(--accent);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .about__inner {
      grid-template-columns: 340px 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 768px) {
    .about__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about__image-frame {
      max-width: 360px;
    }
  }
</style>
