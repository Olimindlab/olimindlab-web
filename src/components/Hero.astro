---
---

<section class="hero" id="inicio">
  <div class="hero__bg-grid"></div>

  <div class="container hero__inner">
    <div class="hero__tag">
      <span class="hero__tag-dot"></span>
      Diseño · Marketing · Identidad
    </div>

    <h1 class="hero__heading">
      <span class="hero__heading-line">Marcas que</span>
      <span class="hero__heading-line hero__heading-italic">no se</span>
      <span class="hero__heading-line hero__heading-block">
        olvidan
        <span class="hero__heading-accent">.</span>
      </span>
    </h1>

    <div class="hero__bottom">
      <p class="hero__desc">
        Consultoría creativa para empresas que quieren destacar.<br />
        Estrategia, diseño y comunicación con intención.
      </p>

      <div class="hero__actions">
        <a href="#servicios" class="hero__btn hero__btn--primary">Ver servicios</a>
        <a href="#contacto" class="hero__btn hero__btn--ghost">Iniciar proyecto →</a>
      </div>

      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">+80</span>
          <span class="hero__stat-label">Proyectos</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">7+</span>
          <span class="hero__stat-label">Años de experiencia</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">100%</span>
          <span class="hero__stat-label">Satisfacción</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__scroll">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-text">Scroll</span>
  </div>

  <div class="hero__marquee-wrap">
    <div class="hero__marquee">
      <span>Branding</span>
      <span class="hero__marquee-dot">●</span>
      <span>Diseño Web</span>
      <span class="hero__marquee-dot">●</span>
      <span>Marketing Digital</span>
      <span class="hero__marquee-dot">●</span>
      <span>Redes Sociales</span>
      <span class="hero__marquee-dot">●</span>
      <span>Identidad Visual</span>
      <span class="hero__marquee-dot">●</span>
      <span>Estrategia</span>
      <span class="hero__marquee-dot">●</span>
      <span>Branding</span>
      <span class="hero__marquee-dot">●</span>
      <span>Diseño Web</span>
      <span class="hero__marquee-dot">●</span>
      <span>Marketing Digital</span>
      <span class="hero__marquee-dot">●</span>
      <span>Redes Sociales</span>
      <span class="hero__marquee-dot">●</span>
      <span>Identidad Visual</span>
      <span class="hero__marquee-dot">●</span>
      <span>Estrategia</span>
      <span class="hero__marquee-dot">●</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-top: 6rem;
  }

  .hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 40%, transparent 100%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg-2);
  }

  .hero__tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero__heading {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 4rem;
  }

  .hero__heading-line {
    font-family: var(--font-display);
    font-size: clamp(5rem, 14vw, 13rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    display: block;
  }

  .hero__heading-italic {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(4rem, 11vw, 10rem);
    color: var(--text-muted);
    padding-left: 2rem;
  }

  .hero__heading-block {
    position: relative;
  }

  .hero__heading-accent {
    color: var(--accent);
  }

  .hero__bottom {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 2rem 4rem;
    align-items: end;
  }

  .hero__desc {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 38ch;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    grid-row: 2;
  }

  .hero__btn {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.875rem 2rem;
    transition: all 0.25s ease;
  }

  .hero__btn--primary {
    background: var(--accent);
    color: var(--text);
  }

  .hero__btn--primary:hover {
    background: var(--accent-2);
    transform: translateY(-2px);
  }

  .hero__btn--ghost {
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 0;
  }

  .hero__btn--ghost:hover {
    color: var(--text);
    border-color: var(--text);
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: end;
    padding: 2rem;
    border: 1px solid var(--border);
    background: var(--bg-2);
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero__stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text);
  }

  .hero__stat-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .hero__stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--border);
  }

  .hero__scroll {
    position: absolute;
    left: 2rem;
    bottom: 8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 1;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  .hero__scroll-text {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    writing-mode: vertical-rl;
  }

  .hero__marquee-wrap {
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 0;
    margin-top: auto;
    background: var(--bg-2);
  }

  .hero__marquee {
    display: flex;
    gap: 3rem;
    align-items: center;
    white-space: nowrap;
    animation: marquee 20s linear infinite;
    width: max-content;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
  }

  .hero__marquee-dot {
    color: var(--accent);
    font-size: 0.5rem;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .hero__bottom {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .hero__stats {
      grid-column: 1;
      grid-row: auto;
      align-self: auto;
    }

    .hero__scroll {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .hero__stats {
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .hero__stat-divider {
      display: none;
    }

    .hero__heading-italic {
      padding-left: 1rem;
    }
  }
</style>
