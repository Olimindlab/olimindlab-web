---
---

<section class="hero" id="inicio">
  <div class="container hero__inner">

    <p class="hero__label">DISEÑO · MARCA · MARKETING</p>

    <h1 class="hero__heading">
      Hacemos que tu marca<br />sea imposible de ignorar.
    </h1>

    <div class="hero__bottom">
      <p class="hero__sub">
        Consultoría de diseño y marketing para marcas<br />
        que quieren destacar de verdad.
      </p>
      <a href="#portfolio" class="hero__link">
        Ver nuestro trabajo
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.5 9h11M10.5 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>

  <div class="hero__services">
    <div class="container hero__services-inner">
      <div class="hero__service">
        <span class="hero__service-num">01</span>
        <span class="hero__service-name">Branding</span>
      </div>
      <div class="hero__service">
        <span class="hero__service-num">02</span>
        <span class="hero__service-name">Web Design</span>
      </div>
      <div class="hero__service">
        <span class="hero__service-num">03</span>
        <span class="hero__service-name">Marketing Digital</span>
      </div>
      <div class="hero__service">
        <span class="hero__service-num">04</span>
        <span class="hero__service-name">Social Media</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 72px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background-color: #ffffff;
    color: #0a0a0a;
  }

  .hero__inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 8rem;
    padding-bottom: 6rem;
  }

  .hero__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 2.5rem;
  }

  .hero__heading {
    font-size: clamp(2.75rem, 6.5vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--black);
    margin-bottom: 4rem;
    max-width: 16ch;
  }

  .hero__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero__sub {
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--muted);
    max-width: 38ch;
  }

  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--black);
    white-space: nowrap;
    border-bottom: 1px solid var(--black);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s, gap 0.2s;
    flex-shrink: 0;
  }

  .hero__link:hover {
    color: var(--accent);
    border-color: var(--accent);
    gap: 0.875rem;
  }

  .hero__services {
    border-top: 1px solid #e8e8e8;
    background-color: #ffffff;
  }

  .hero__services-inner {
    display: flex;
    flex-direction: row;
  }

  .hero__service {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 2rem 2.5rem 2rem 0;
    flex: 1;
    border-right: 1px solid #e8e8e8;
  }

  .hero__service:first-child {
    padding-left: 0;
  }

  .hero__service:last-child {
    border-right: none;
  }

  .hero__service-num {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .hero__service-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--black);
    letter-spacing: -0.01em;
  }

  @media (max-width: 768px) {
    .hero__inner {
      padding-top: 5rem;
      padding-bottom: 4rem;
    }

    .hero__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }

    .hero__services-inner {
      flex-wrap: wrap;
    }

    .hero__service {
      flex: 0 0 50%;
      padding: 1.5rem 1.5rem 1.5rem 0;
    }

    .hero__service:nth-child(2) {
      border-right: none;
    }

    .hero__service:nth-child(3),
    .hero__service:nth-child(4) {
      border-top: 1px solid #e8e8e8;
    }
  }
</style>
