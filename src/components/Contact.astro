---
---

<section class="contact" id="contacto">
  <div class="container contact__inner">
    <div class="contact__left">
      <div class="contact__label">
        <span class="contact__label-line"></span>
        <span>Contacto</span>
      </div>

      <h2 class="contact__title">
        ¿Listo para
        <br />
        <em>empezar?</em>
      </h2>

      <p class="contact__desc">
        Cuéntame sobre tu proyecto. Sin compromiso, sin formularios interminables.
        Solo una conversación honesta para ver si podemos trabajar juntos.
      </p>

      <div class="contact__info">
        <a href="mailto:hola@olimindlab.com" class="contact__info-item">
          <span class="contact__info-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 4.5h12a1.5 1.5 0 0 1 1.5 1.5v6a1.5 1.5 0 0 1-1.5 1.5H3A1.5 1.5 0 0 1 1.5 12V6A1.5 1.5 0 0 1 3 4.5z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              <path d="m16.5 6-7.5 5.25L1.5 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </span>
          <span>hola@olimindlab.com</span>
        </a>
        <a href="https://instagram.com/olimindlab" target="_blank" rel="noopener" class="contact__info-item">
          <span class="contact__info-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="1.5" y="1.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.25"/>
              <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.25"/>
              <circle cx="13" cy="5" r="0.75" fill="currentColor"/>
            </svg>
          </span>
          <span>@olimindlab</span>
        </a>
        <a href="https://linkedin.com/in/olimindlab" target="_blank" rel="noopener" class="contact__info-item">
          <span class="contact__info-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="1.5" y="1.5" width="15" height="15" rx="2" stroke="currentColor" stroke-width="1.25"/>
              <path d="M5 7.5v5M5 5.5v.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              <path d="M8 12.5v-3a2 2 0 0 1 4 0v3M8 7.5v5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span>LinkedIn</span>
        </a>
      </div>

      <div class="contact__availability">
        <span class="contact__availability-dot"></span>
        Disponible para proyectos nuevos
      </div>
    </div>

    <div class="contact__right">
      <form class="contact__form" id="contact-form" novalidate>
        <div class="contact__field">
          <label class="contact__label-field" for="name">Nombre *</label>
          <input
            class="contact__input"
            type="text"
            id="name"
            name="name"
            placeholder="Tu nombre"
            required
          />
        </div>

        <div class="contact__field">
          <label class="contact__label-field" for="email">Email *</label>
          <input
            class="contact__input"
            type="email"
            id="email"
            name="email"
            placeholder="tu@email.com"
            required
          />
        </div>

        <div class="contact__field">
          <label class="contact__label-field" for="service">Servicio de interés</label>
          <select class="contact__input contact__select" id="service" name="service">
            <option value="" disabled selected>Selecciona un servicio</option>
            <option value="branding">Branding e identidad visual</option>
            <option value="web">Diseño web</option>
            <option value="marketing">Marketing digital</option>
            <option value="social">Redes sociales</option>
            <option value="other">Otro / No sé aún</option>
          </select>
        </div>

        <div class="contact__field">
          <label class="contact__label-field" for="budget">Presupuesto aproximado</label>
          <select class="contact__input contact__select" id="budget" name="budget">
            <option value="" disabled selected>Rango de inversión</option>
            <option value="500-1500">500€ – 1.500€</option>
            <option value="1500-5000">1.500€ – 5.000€</option>
            <option value="5000-15000">5.000€ – 15.000€</option>
            <option value="15000+">+15.000€</option>
            <option value="unknown">Aún no lo sé</option>
          </select>
        </div>

        <div class="contact__field contact__field--full">
          <label class="contact__label-field" for="message">Cuéntame sobre tu proyecto *</label>
          <textarea
            class="contact__input contact__textarea"
            id="message"
            name="message"
            placeholder="¿Qué quieres conseguir? ¿Cuál es tu reto? Cuanto más detallas, mejor puedo ayudarte."
            rows="5"
            required
          ></textarea>
        </div>

        <div class="contact__field contact__field--full">
          <button type="submit" class="contact__submit">
            <span class="contact__submit-text">Enviar mensaje</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </form>

      <div class="contact__success" id="contact-success">
        <div class="contact__success-icon">✓</div>
        <h3 class="contact__success-title">¡Mensaje enviado!</h3>
        <p class="contact__success-desc">Me pondré en contacto contigo en menos de 48h.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 8rem 0;
    position: relative;
  }

  .contact::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  /* Left */
  .contact__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .contact__label-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--accent);
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 0.9;
    margin-bottom: 1.75rem;
  }

  .contact__title em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .contact__desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 3rem;
    max-width: 38ch;
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .contact__info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.9375rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .contact__info-item:hover {
    color: var(--text);
  }

  .contact__info-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    background: var(--bg-2);
    flex-shrink: 0;
    color: var(--accent);
    transition: background 0.2s;
  }

  .contact__info-item:hover .contact__info-icon {
    background: var(--bg-3);
  }

  .contact__availability {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .contact__availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    animation: pulse-green 2s ease-in-out infinite;
  }

  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
  }

  /* Form */
  .contact__form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact__field--full {
    grid-column: 1 / -1;
  }

  .contact__label-field {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
  }

  .contact__input {
    background: var(--bg-2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.875rem 1rem;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    font-weight: 300;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
    appearance: none;
  }

  .contact__input::placeholder {
    color: #444;
  }

  .contact__input:focus {
    border-color: var(--accent);
  }

  .contact__select {
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23888' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .contact__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1.125rem 2rem;
    background: var(--accent);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-family: var(--font-body);
    transition: background 0.2s, gap 0.2s;
    cursor: pointer;
    border: none;
  }

  .contact__submit:hover {
    background: var(--accent-2);
    gap: 1.25rem;
  }

  .contact__submit:active {
    transform: scale(0.99);
  }

  .contact__success {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    padding: 4rem 2rem;
    border: 1px solid var(--border);
    background: var(--bg-2);
  }

  .contact__success.visible {
    display: flex;
  }

  .contact__success-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 300;
  }

  .contact__success-title {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.05em;
  }

  .contact__success-desc {
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  @media (max-width: 900px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 600px) {
    .contact__form {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("contact-success");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = data.get("name") as string;
    const email = data.get("email") as string;
    const message = data.get("message") as string;

    if (!name.trim() || !email.trim() || !message.trim()) return;

    // Simulate form submission
    const btn = form.querySelector(".contact__submit") as HTMLButtonElement;
    btn.disabled = true;
    btn.querySelector(".contact__submit-text")!.textContent = "Enviando...";

    setTimeout(() => {
      form.style.display = "none";
      success?.classList.add("visible");
    }, 1200);
  });
</script>
