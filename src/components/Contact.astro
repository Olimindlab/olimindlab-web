---
---

<section class="contact" id="contacto">
  <div class="container contact__inner">

    <div class="contact__left">
      <p class="contact__label">CONTACTO</p>
      <h2 class="contact__title">¿Tienes un<br />proyecto en mente?</h2>
      <p class="contact__desc">
        Cuéntanos qué necesitas. Sin compromiso y sin formularios interminables.
        Solo una conversación para ver si encajamos.
      </p>

      <div class="contact__details">
        <div class="contact__detail">
          <span class="contact__detail-label">Email</span>
          <a href="mailto:hola@olimindlab.com" class="contact__detail-value">
            hola@olimindlab.com
          </a>
        </div>
        <div class="contact__detail">
          <span class="contact__detail-label">Instagram</span>
          <a href="https://instagram.com/olimindlab" target="_blank" rel="noopener" class="contact__detail-value">
            @olimindlab
          </a>
        </div>
        <div class="contact__detail">
          <span class="contact__detail-label">LinkedIn</span>
          <a href="https://linkedin.com/in/olimindlab" target="_blank" rel="noopener" class="contact__detail-value">
            Olimindlab
          </a>
        </div>
      </div>

      <div class="contact__status">
        <span class="contact__status-dot"></span>
        Disponible para nuevos proyectos
      </div>
    </div>

    <div class="contact__right">
      <form class="contact__form" id="contact-form" novalidate>
        <div class="field">
          <label class="field__label" for="name">Nombre *</label>
          <input class="field__input" type="text" id="name" name="name" placeholder="Tu nombre" required />
        </div>

        <div class="field">
          <label class="field__label" for="email">Email *</label>
          <input class="field__input" type="email" id="email" name="email" placeholder="tu@email.com" required />
        </div>

        <div class="field field--full">
          <label class="field__label" for="service">¿Qué necesitas?</label>
          <select class="field__input field__select" id="service" name="service">
            <option value="" disabled selected>Selecciona un servicio</option>
            <option value="branding">Branding e identidad visual</option>
            <option value="web">Web Design</option>
            <option value="marketing">Marketing Digital</option>
            <option value="social">Social Media</option>
            <option value="other">Otro</option>
          </select>
        </div>

        <div class="field field--full">
          <label class="field__label" for="message">Tu proyecto *</label>
          <textarea
            class="field__input field__textarea"
            id="message"
            name="message"
            placeholder="Cuéntanos sobre tu marca, tus objetivos y lo que buscas conseguir."
            rows="5"
            required
          ></textarea>
        </div>

        <div class="field field--full">
          <button type="submit" class="contact__submit">
            <span id="submit-text">Enviar mensaje</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9h11M10.5 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </form>

      <div class="contact__success" id="contact-success">
        <p class="contact__success-title">Mensaje enviado.</p>
        <p class="contact__success-desc">Te responderemos en menos de 48 horas.</p>
      </div>
    </div>

  </div>
</section>

<style>
  .contact {
    padding: 10rem 0;
    background-color: #f5f4f0;
    color: #0a0a0a;
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: start;
  }

  .contact__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .contact__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .contact__desc {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .contact__detail {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .contact__detail-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .contact__detail-value {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--black);
    transition: color 0.2s;
  }

  .contact__detail-value:hover {
    color: var(--accent);
  }

  .contact__status {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .contact__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
  }

  /* Form */
  .contact__form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field--full {
    grid-column: 1 / -1;
  }

  .field__label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--black);
  }

  .field__input {
    background: var(--white);
    border: 1px solid var(--border);
    color: var(--black);
    padding: 0.875rem 1rem;
    font-size: 0.9375rem;
    font-weight: 400;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
    appearance: none;
    border-radius: 0;
  }

  .field__input::placeholder {
    color: #bbb;
  }

  .field__input:focus {
    border-color: var(--black);
  }

  .field__select {
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%236b6b6b' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-color: var(--white);
    padding-right: 2.5rem;
  }

  .field__textarea {
    resize: vertical;
    min-height: 130px;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: 100%;
    padding: 1rem 2rem;
    background: var(--accent);
    color: var(--white);
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: background 0.2s, gap 0.2s;
  }

  .contact__submit:hover {
    background: var(--black);
    gap: 1rem;
  }

  .contact__success {
    display: none;
    padding: 4rem 2rem;
    text-align: center;
    border: 1px solid var(--border);
    background: var(--white);
  }

  .contact__success.visible {
    display: block;
  }

  .contact__success-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .contact__success-desc {
    font-size: 0.9375rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 600px) {
    .contact__form {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const success = document.getElementById("contact-success");
  const submitText = document.getElementById("submit-text");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    if (!data.get("name") || !data.get("email") || !data.get("message")) return;

    const btn = form.querySelector(".contact__submit") as HTMLButtonElement;
    btn.disabled = true;
    if (submitText) submitText.textContent = "Enviando...";

    setTimeout(() => {
      form.style.display = "none";
      success?.classList.add("visible");
    }, 1000);
  });
</script>
