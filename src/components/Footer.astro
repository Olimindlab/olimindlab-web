---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="#inicio" class="footer__logo">
          <span>OLIMIND</span><span class="footer__logo-accent">LAB</span>
        </a>
        <p class="footer__tagline">
          Diseño y marketing digital<br />con propósito e intención.
        </p>
      </div>

      <nav class="footer__nav">
        <div class="footer__nav-col">
          <h4 class="footer__nav-title">Servicios</h4>
          <ul class="footer__nav-list">
            <li><a href="#servicios">Branding</a></li>
            <li><a href="#servicios">Diseño Web</a></li>
            <li><a href="#servicios">Marketing Digital</a></li>
            <li><a href="#servicios">Redes Sociales</a></li>
          </ul>
        </div>
        <div class="footer__nav-col">
          <h4 class="footer__nav-title">Empresa</h4>
          <ul class="footer__nav-list">
            <li><a href="#sobre-mi">Sobre mí</a></li>
            <li><a href="#proceso">Proceso</a></li>
            <li><a href="#testimonios">Clientes</a></li>
            <li><a href="#contacto">Contacto</a></li>
          </ul>
        </div>
        <div class="footer__nav-col">
          <h4 class="footer__nav-title">Conecta</h4>
          <ul class="footer__nav-list">
            <li><a href="mailto:hola@olimindlab.com">Email</a></li>
            <li><a href="https://instagram.com/olimindlab" target="_blank" rel="noopener">Instagram</a></li>
            <li><a href="https://linkedin.com/in/olimindlab" target="_blank" rel="noopener">LinkedIn</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">
        © {year} Olimindlab. Todos los derechos reservados.
      </p>
      <div class="footer__legal">
        <a href="#">Política de privacidad</a>
        <a href="#">Aviso legal</a>
      </div>
      <p class="footer__made">
        Hecho con <span class="footer__heart">♥</span> en España
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg);
    padding: 5rem 0 2.5rem;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.75rem;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 1.25rem;
    transition: opacity 0.2s;
  }

  .footer__logo:hover {
    opacity: 0.8;
  }

  .footer__logo-accent {
    color: var(--accent);
  }

  .footer__tagline {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    justify-self: end;
    width: 100%;
  }

  .footer__nav-title {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-weight: 500;
  }

  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__nav-list a {
    font-size: 0.9375rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer__nav-list a:hover {
    color: var(--text);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer__legal a {
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer__legal a:hover {
    color: var(--text);
  }

  .footer__made {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .footer__heart {
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer__nav {
      justify-self: start;
    }
  }

  @media (max-width: 600px) {
    .footer__nav {
      grid-template-columns: 1fr 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
