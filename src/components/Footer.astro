---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <a href="#inicio" class="footer__logo">Olimindlab</a>
      <p class="footer__tagline">Diseño y marketing para marcas que quieren destacar.</p>
      <nav class="footer__nav" aria-label="Footer">
        <a href="#servicios" class="footer__link">Servicios</a>
        <a href="#portfolio" class="footer__link">Portfolio</a>
        <a href="#sobre-mi" class="footer__link">Sobre mí</a>
        <a href="#contacto" class="footer__link">Contacto</a>
      </nav>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">© {year} Olimindlab. Todos los derechos reservados.</p>
      <div class="footer__legal">
        <a href="#" class="footer__legal-link">Política de privacidad</a>
        <a href="#" class="footer__legal-link">Aviso legal</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 5rem 0 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    gap: 3rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .footer__logo {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--black);
  }

  .footer__tagline {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .footer__nav {
    display: flex;
    gap: 2rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .footer__link:hover {
    color: var(--black);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer__copy {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer__legal-link {
    font-size: 0.8125rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .footer__legal-link:hover {
    color: var(--black);
  }

  @media (max-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .footer__nav {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
