---
const services = [
  {
    num: "01",
    title: "Branding",
    desc: "Construimos identidades visuales coherentes y memorables. Logotipo, sistema de diseño, manual de marca y todo lo que necesitas para comunicar quién eres con consistencia.",
    items: ["Logotipo", "Identidad visual", "Manual de marca", "Naming", "Tono de voz"],
  },
  {
    num: "02",
    title: "Web Design",
    desc: "Diseñamos y desarrollamos sitios web que combinan estética y rendimiento. Cada página pensada para convertir visitantes en clientes.",
    items: ["UX/UI Design", "Desarrollo web", "Landing pages", "Ecommerce", "Optimización"],
  },
  {
    num: "03",
    title: "Marketing Digital",
    desc: "Estrategia y ejecución de marketing con foco en resultados. SEO, campañas de pago y email marketing con métricas claras y transparentes.",
    items: ["SEO", "Google Ads", "Meta Ads", "Email marketing", "Analítica"],
  },
  {
    num: "04",
    title: "Social Media",
    desc: "Gestión integral de redes sociales. Creación de contenido, calendario editorial y community management para construir comunidades que convierten.",
    items: ["Estrategia de contenido", "Diseño de posts", "Community", "Instagram", "LinkedIn"],
  },
];
---

<section class="services" id="servicios">
  <div class="container">

    <div class="services__header">
      <p class="services__label">SERVICIOS</p>
      <h2 class="services__title">Todo lo que<br />tu marca necesita.</h2>
    </div>

    <div class="services__list">
      {services.map((s) => (
        <div class="service">
          <div class="service__left">
            <span class="service__num">{s.num}</span>
          </div>
          <div class="service__center">
            <h3 class="service__title">{s.title}</h3>
            <p class="service__desc">{s.desc}</p>
          </div>
          <div class="service__right">
            <ul class="service__items">
              {s.items.map((item) => (
                <li class="service__item">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="services__footer">
      <a href="#contacto" class="btn">Cuéntanos tu proyecto</a>
    </div>

  </div>
</section>

<style>
  .services {
    padding: 10rem 0;
    background-color: #f5f4f0;
    color: #0a0a0a;
  }

  .services__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 2rem;
    margin-bottom: 6rem;
  }

  .services__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--muted);
    align-self: start;
    padding-top: 0.5rem;
  }

  .services__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .services__list {
    border-top: 1px solid var(--border);
  }

  .service {
    display: grid;
    grid-template-columns: 80px 1fr 240px;
    gap: 3rem;
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }

  .service__num {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--accent);
    padding-top: 0.375rem;
  }

  .service__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .service__desc {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 48ch;
  }

  .service__items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.375rem;
  }

  .service__item {
    font-size: 0.875rem;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
  }

  .service__item::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .services__footer {
    margin-top: 5rem;
    display: flex;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--white);
    background: var(--accent);
    padding: 0.875rem 2rem;
    transition: background 0.2s;
  }

  .btn:hover {
    background: var(--black);
  }

  @media (max-width: 900px) {
    .service {
      grid-template-columns: 60px 1fr;
      grid-template-rows: auto auto;
    }

    .service__right {
      grid-column: 2;
    }
  }

  @media (max-width: 600px) {
    .services__header {
      grid-template-columns: 1fr;
    }

    .service {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .service__right {
      grid-column: 1;
    }
  }
</style>
