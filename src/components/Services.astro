---
const services = [
  {
    num: "01",
    title: "Branding",
    subtitle: "Identidad que perdura",
    desc: "Creamos la identidad visual completa de tu marca: logotipo, paleta, tipografías, tono de voz y manual de marca. Todo lo que necesitas para comunicar quién eres de forma coherente y memorable.",
    tags: ["Logo", "Manual de marca", "Identidad visual", "Naming"],
    highlight: true,
  },
  {
    num: "02",
    title: "Diseño Web",
    subtitle: "Presencia digital de impacto",
    desc: "Diseñamos y desarrollamos sitios web que convierten visitantes en clientes. Experiencias digitales rápidas, accesibles y visualmente potentes.",
    tags: ["UX/UI", "Desarrollo", "Landing pages", "Ecommerce"],
    highlight: false,
  },
  {
    num: "03",
    title: "Marketing Digital",
    subtitle: "Estrategia con propósito",
    desc: "Definimos la estrategia de marketing que necesitas para crecer. SEO, campañas de pago, email marketing y analítica orientada a resultados reales.",
    tags: ["SEO", "SEM", "Email marketing", "Analytics"],
    highlight: false,
  },
  {
    num: "04",
    title: "Redes Sociales",
    subtitle: "Comunidades que conectan",
    desc: "Gestión integral de tu presencia en redes sociales. Creación de contenido, calendario editorial, community management y crecimiento orgánico.",
    tags: ["Instagram", "LinkedIn", "Contenido", "Community"],
    highlight: false,
  },
];
---

<section class="services" id="servicios">
  <div class="container">
    <div class="services__header">
      <div class="services__label">
        <span class="services__label-line"></span>
        <span>Servicios</span>
      </div>
      <h2 class="services__title">
        Lo que hago<br />
        <span class="services__title-italic">mejor</span>
      </h2>
    </div>

    <div class="services__grid">
      {services.map((s) => (
        <article class={`service-card ${s.highlight ? "service-card--highlight" : ""}`}>
          <div class="service-card__top">
            <span class="service-card__num">{s.num}</span>
            <span class="service-card__subtitle">{s.subtitle}</span>
          </div>

          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>

          <div class="service-card__tags">
            {s.tags.map((tag) => (
              <span class="service-card__tag">{tag}</span>
            ))}
          </div>

          <a href="#contacto" class="service-card__link">
            Empezar proyecto
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 8rem 0;
    position: relative;
  }

  .services::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .services__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 5rem;
    gap: 2rem;
  }

  .services__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }

  .services__label-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--accent);
  }

  .services__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 6rem);
    line-height: 0.9;
    text-align: right;
  }

  .services__title-italic {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .service-card {
    background: var(--bg);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: background 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.5s ease;
  }

  .service-card:hover {
    background: var(--bg-2);
  }

  .service-card:hover::after {
    width: 100%;
  }

  .service-card--highlight {
    background: var(--bg-2);
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .service-card--highlight .service-card__title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
  }

  .service-card--highlight .service-card__desc {
    font-size: 1.0625rem;
  }

  .service-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .service-card__num {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .service-card__subtitle {
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    margin-top: auto;
  }

  .service-card__desc {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
    flex: 1;
  }

  .service-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .service-card__tag {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-3);
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    transition: gap 0.2s ease;
    margin-top: 1rem;
  }

  .service-card__link:hover {
    gap: 0.875rem;
  }

  @media (max-width: 900px) {
    .services__grid {
      grid-template-columns: 1fr;
    }

    .service-card--highlight {
      grid-column: 1;
      grid-row: auto;
    }

    .services__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .services__title {
      text-align: left;
    }
  }

  @media (max-width: 600px) {
    .service-card {
      padding: 2rem;
    }
  }
</style>
